#include <stdio.h>
#include <string.h>
#include "generer.h"
FILE *f;
char nom[20],prenom[40], telephone[15], genre[20];
int age, i, n;
int generer_table(const char *nom_fichier){
    f = fopen(nom_fichier,"w");
    if(f==0){
        printf("erreur lors de la creation");
        return 1;
    }
    printf("saisissez le nombre de personne : ");
    scanf("%d" ,&n);
    fprintf(f,"%-20s  %-20s  %-20s  %-10s  %-5s\n", "Nom", "Prenom", "Telephone", "Genre", "Age");
    for(i=0; i<n; i++){
        printf("saisie de la personne n%d" ,i+1);
        printf("nom : ");
        scanf("%s", nom);
        printf("prenom : ");
        scanf("%s", prenom);
        printf("telephone : ");
        scanf("%s", telephone);
        printf("genre : ");
        scanf("%s", genre);
        printf("age : ");
        scanf("%d", &age);
        fprintf(f,"%-20s  %-20s  %-20s  %-10s  %-5d\n", nom, prenom, telephone, genre, age); 
    }
    fclose(f);
    return 0;
}
